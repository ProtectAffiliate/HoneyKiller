{
  "manifest_version": 3,
  "name": "HoneyKiller — Commission Protection",
  "short_name": "HoneyKiller",
  "version": "1.0.0",
  "description": "Blocks Honey, Capital One Shopping, Rakuten and other extensions that override affiliate attribution at checkout. Protects your affiliate earnings. Free. Open source.",

  "permissions": ["storage"],

  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.com.au/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.in/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.it/*",
    "*://*.amazon.es/*",
    "*://*.shareasale.com/*",
    "*://*.cj.com/*",
    "*://*.pepperjam.com/*",
    "*://*.awin.com/*",
    "*://*.clickbank.net/*",
    "*://*.impact.com/*",
    "*://*.ebay.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.co.uk/*",
        "*://*.amazon.ca/*",
        "*://*.amazon.com.au/*",
        "*://*.amazon.de/*",
        "*://*.amazon.fr/*",
        "*://*.amazon.in/*",
        "*://*.amazon.co.jp/*",
        "*://*.amazon.it/*",
        "*://*.amazon.es/*",
        "*://*.shareasale.com/*",
        "*://*.cj.com/*",
        "*://*.pepperjam.com/*",
        "*://*.awin.com/*",
        "*://*.clickbank.net/*",
        "*://*.impact.com/*",
        "*://*.ebay.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "HoneyKiller — Commission Protection"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
